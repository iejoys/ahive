    {
      "id": "phase-design",
      "type": "milestone",
      "name": "阶段一：需求与设计",
      "position": {
        "x": 300,
        "y": 300
      },
      "config": {
        "description": "完成需求分析、游戏设计、技术架构规划",
        "waitForCompletion": true,
        "childNodes": [
          "req-analysis",
          "game-design",
          "design-review"
        ]
      }
    },
    {
      "id": "req-analysis",
      "type": "agent",
      "name": "需求分析",
      "position": {
        "x": 500,
        "y": 150
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "analyst-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "分析2D塔防游戏需求：核心玩法、塔类型、敌人类型、关卡设计、经济系统。输出需求文档到 {{project.projectDir}}/docs/requirements.md",
        "outputs": [
          {
            "name": "requirementsDoc",
            "extractPath": "$"
          }
        ],
        "timeout": 3600000
      }
    },
    {
      "id": "game-design",
      "type": "agent",
      "name": "游戏系统设计",
      "position": {
        "x": 700,
        "y": 150
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "designer-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "基于需求文档设计游戏系统：关卡流程、数值平衡、UI交互。输出GDD到 {{project.designerDir}}/GDD.md",
        "inputs": [
          {
            "name": "requirementsDoc",
            "source": "prev-output",
            "sourceKey": "req-analysis:requirementsDoc"
          }
        ],
        "outputs": [
          {
            "name": "gameDesignDoc",
            "extractPath": "$"
          }
        ],
        "timeout": 3600000
      }
    },
    {
      "id": "design-review",
      "type": "review",
      "name": "设计方案审核",
      "position": {
        "x": 900,
        "y": 150
      },
      "config": {
        "reviewConfig": {
          "reviewType": "agent",
          "reviewerAgentId": "reviewer-agent",
          "title": "设计文档审核",
          "instruction": "审核GDD的完整性、可行性、数值合理性。90分通过。",
          "scoreMethod": "score",
          "criteria": [
            {
              "name": "完整性",
              "description": "是否覆盖所有核心模块",
              "weight": 40
            },
            {
              "name": "可行性",
              "description": "技术实现难度评估",
              "weight": 30
            },
            {
              "name": "数值平衡",
              "description": "经济系统与难度曲线",
              "weight": 30
            }
          ],
          "passCondition": {
            "variableName": "totalScore",
            "operator": "gte",
            "threshold": 90
          },
          "failAction": {
            "type": "return",
            "targetNodeId": "game-design",
            "maxRetries": 3
          }
        }
      }
    },
    {
      "id": "phase-dev",
      "type": "milestone",
      "name": "阶段二：核心开发",
      "position": {
        "x": 1100,
        "y": 300
      },
      "config": {
        "description": "并行开发代码、美术、音频，各自隔离目录",
        "waitForCompletion": true,
        "childNodes": [
          "parallel-dev",
          "dev-code",
          "dev-art",
          "dev-audio",
          "code-review",
          "art-review",
          "audio-review",
          "integration"
        ]
      }
    },
    {
      "id": "parallel-dev",
      "type": "parallel",
      "name": "并行开发分支",
      "position": {
        "x": 1300,
        "y": 150
      },
      "config": {
        "branches": [
          "dev-code",
          "dev-art",
          "dev-audio"
        ],
        "mergeType": "all"
      }
    },
    {
      "id": "dev-code",
      "type": "agent",
      "name": "核心代码开发",
      "position": {
        "x": 1500,
        "y": 50
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "coder-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "使用 {{project.techStack}} 开发核心逻辑：地图网格、寻路算法、塔逻辑、碰撞检测。代码输出到 {{project.coderDir}}",
        "inputs": [
          {
            "name": "gameDesignDoc",
            "source": "prev-output",
            "sourceKey": "game-design:gameDesignDoc"
          }
        ],
        "outputs": [
          {
            "name": "codeOutput",
            "extractPath": "$"
          }
        ],
        "timeout": 7200000
      }
    },
    {
      "id": "code-review",
      "type": "review",
      "name": "代码质量审核",
      "position": {
        "x": 1700,
        "y": 50
      },
      "config": {
        "reviewConfig": {
          "reviewType": "agent",
          "reviewerAgentId": "reviewer-agent",
          "title": "代码审核",
          "instruction": "审核代码规范、性能、架构设计。90分通过。",
          "scoreMethod": "score",
          "criteria": [
            {
              "name": "规范",
              "description": "TypeScript 类型安全与注释",
              "weight": 30
            },
            {
              "name": "架构",
              "description": "模块化与ECS实现",
              "weight": 40
            },
            {
              "name": "性能",
              "description": "渲染与计算效率",
              "weight": 30
            }
          ],
          "passCondition": {
            "variableName": "totalScore",
            "operator": "gte",
            "threshold": 90
          },
          "failAction": {
            "type": "return",
            "targetNodeId": "dev-code",
            "maxRetries": 3
          }
        }
      }
    },
    {
      "id": "dev-art",
      "type": "agent",
      "name": "美术资源制作",
      "position": {
        "x": 1500,
        "y": 250
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "artist-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "制作2D美术资源：塔、敌人、地图、UI。资源输出到 {{project.artistDir}}",
        "inputs": [
          {
            "name": "gameDesignDoc",
            "source": "prev-output",
            "sourceKey": "game-design:gameDesignDoc"
          }
        ],
        "outputs": [
          {
            "name": "artOutput",
            "extractPath": "$"
          }
        ],
        "timeout": 5400000
      }
    },
    {
      "id": "art-review",
      "type": "review",
      "name": "美术资源审核",
      "position": {
        "x": 1700,
        "y": 250
      },
      "config": {
        "reviewConfig": {
          "reviewType": "agent",
          "reviewerAgentId": "reviewer-agent",
          "title": "美术审核",
          "instruction": "审核风格统一性、分辨率、动画流畅度。90分通过。",
          "scoreMethod": "score",
          "criteria": [
            {
              "name": "风格",
              "description": "视觉风格一致性",
              "weight": 40
            },
            {
              "name": "质量",
              "description": "贴图精度与动画",
              "weight": 30
            },
            {
              "name": "规范",
              "description": "文件命名与格式",
              "weight": 30
            }
          ],
          "passCondition": {
            "variableName": "totalScore",
            "operator": "gte",
            "threshold": 90
          },
          "failAction": {
            "type": "return",
            "targetNodeId": "dev-art",
            "maxRetries": 3
          }
        }
      }
    },
    {
      "id": "dev-audio",
      "type": "agent",
      "name": "音频资源制作",
      "position": {
        "x": 1500,
        "y": 450
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "audio-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "制作音效与BGM：攻击、建造、背景音乐。音频输出到 {{project.audioDir}}",
        "inputs": [
          {
            "name": "gameDesignDoc",
            "source": "prev-output",
            "sourceKey": "game-design:gameDesignDoc"
          }
