    {
      "id": "phase-test",
      "type": "milestone",
      "name": "阶段三：测试与发布",
      "position": {
        "x": 2100,
        "y": 300
      },
      "config": {
        "description": "功能测试、Bug修复、构建发布",
        "waitForCompletion": true,
        "childNodes": [
          "functional-test",
          "bugfix-loop",
          "bugfix",
          "build-release",
          "final-output"
        ]
      }
    },
    {
      "id": "functional-test",
      "type": "agent",
      "name": "功能测试",
      "position": {
        "x": 2300,
        "y": 150
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "tester-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "执行全功能测试：塔放置、敌人路径、技能释放、经济系统。输出测试报告。",
        "outputs": [
          {
            "name": "testReport",
            "extractPath": "$"
          },
          {
            "name": "bugCount",
            "extractPath": "$.bugCount"
          }
        ],
        "timeout": 3600000
      }
    },
    {
      "id": "bugfix-loop",
      "type": "loop",
      "name": "Bug修复循环",
      "position": {
        "x": 2500,
        "y": 150
      },
      "config": {
        "loopConfig": {
          "type": "condition",
          "condition": "{{bugCount}} > 0",
          "loopBodyNode": "bugfix"
        }
      }
    },
    {
      "id": "bugfix",
      "type": "agent",
      "name": "缺陷修复",
      "position": {
        "x": 2700,
        "y": 150
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "coder-agent"
            }
          ],
          "failureStrategy": {
            "action": "retry",
            "retryCount": 3
          }
        },
        "taskTemplate": "根据测试报告修复Bug，代码修改在 {{project.coderDir}} 进行。",
        "inputs": [
          {
            "name": "testReport",
            "source": "prev-output",
            "sourceKey": "functional-test:testReport"
          }
        ],
        "outputs": [
          {
            "name": "fixResult",
            "extractPath": "$"
          }
        ],
        "timeout": 3600000
      }
    },
    {
      "id": "build-release",
      "type": "agent",
      "name": "构建发布",
      "position": {
        "x": 2900,
        "y": 250
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "coder-agent"
            }
          ],
          "failureStrategy": {
            "action": "retry",
            "retryCount": 2
          }
        },
        "taskTemplate": "执行 Vite 构建，优化资源，生成发布包到 {{project.projectDir}}/dist/",
        "timeout": 1800000
      }
    },
    {
      "id": "final-output",
      "type": "output",
      "name": "游戏发布包",
      "position": {
        "x": 3100,
        "y": 250
      },
      "config": {
        "outputConfig": {
          "name": "2D塔防游戏发布包",
          "description": "可运行的最终游戏版本",
          "type": "file",
          "isFinalOutput": true
        }
      }
    }
