        "outputs": [
          {
            "name": "audioOutput",
            "extractPath": "$"
          }
        ],
        "timeout": 3600000
      }
    },
    {
      "id": "audio-review",
      "type": "review",
      "name": "音频资源审核",
      "position": {
        "x": 1700,
        "y": 450
      },
      "config": {
        "reviewConfig": {
          "reviewType": "agent",
          "reviewerAgentId": "reviewer-agent",
          "title": "音频审核",
          "instruction": "审核音效匹配度、音质、循环流畅度。90分通过。",
          "scoreMethod": "score",
          "criteria": [
            {
              "name": "匹配度",
              "description": "音效与游戏行为同步",
              "weight": 40
            },
            {
              "name": "音质",
              "description": "清晰度与无底噪",
              "weight": 30
            },
            {
              "name": "氛围",
              "description": "BGM沉浸感",
              "weight": 30
            }
          ],
          "passCondition": {
            "variableName": "totalScore",
            "operator": "gte",
            "threshold": 90
          },
          "failAction": {
            "type": "return",
            "targetNodeId": "dev-audio",
            "maxRetries": 3
          }
        }
      }
    },
    {
      "id": "integration",
      "type": "agent",
      "name": "资产集成",
      "position": {
        "x": 1900,
        "y": 250
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "coder-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "整合代码、美术、音频到 {{project.projectDir}}，配置资源加载器，调试核心循环。",
        "inputs": [
          {
            "name": "codeOutput",
            "source": "prev-output",
            "sourceKey": "dev-code:codeOutput"
          },
          {
            "name": "artOutput",
            "source": "prev-output",
            "sourceKey": "dev-art:artOutput"
          },
          {
            "name": "audioOutput",
            "source": "prev-output",
            "sourceKey": "dev-audio:audioOutput"
          }
        ],
        "outputs": [
          {
            "name": "integratedBuild",
            "extractPath": "$"
          }
        ],
        "timeout": 3600000
      }
