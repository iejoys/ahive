      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "tester-agent"
            }
          ],
          "failureStrategy": {
            "action": "continue"
          }
        },
        "taskTemplate": "执行单元测试：运行 {{context.assets.tests}} 目录下的所有单元测试用例，记录测试结果和覆盖率",
        "outputs": [
          {
            "name": "unitTestResults",
            "extractPath": "$"
          }
        ],
        "timeout": 1800000,
        "inputs": []
      },
      "updatedAt": "2026-04-09T00:34:59.746Z",
      "description": ""
    },
    {
      "id": "integration-tests",
      "type": "agent",
      "name": "集成测试",
      "position": {
        "x": 698.5197478089012,
        "y": 209.21008764394634
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "tester-agent"
            }
          ],
          "failureStrategy": {
            "action": "continue"
          }
        },
        "taskTemplate": "执行集成测试：测试模块间的交互和数据流，验证系统整体功能",
        "outputs": [
          {
            "name": "integrationTestResults",
            "extractPath": "$"
          }
        ],
        "timeout": 1800000,
        "inputs": []
      },
      "updatedAt": "2026-04-08T02:49:45.835Z",
      "description": ""
    },
    {
      "id": "coverage-analysis",
      "type": "agent",
      "name": "覆盖率分析",
      "position": {
        "x": 1046.5449669187672,
        "y": 105.92100876439463
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "tester-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "分析测试覆盖率：汇总单元测试和集成测试的覆盖率数据，生成覆盖率报告",
        "inputs": [
          {
            "name": "unitResults",
            "source": "prev-output",
            "sourceKey": "unit-tests:unitTestResults"
          },
          {
            "name": "integrationResults",
            "source": "prev-output",
            "sourceKey": "integration-tests:integrationTestResults"
          }
        ],
        "outputs": [
          {
            "name": "coverageReport",
            "extractPath": "$"
          },
          {
            "name": "coverageScore",
            "extractPath": "$.coverageScore"
          }
        ],
        "timeout": 600000
      },
      "updatedAt": "2026-04-09T02:52:52.207Z",
      "description": ""
    },
    {
      "id": "test-condition",
      "type": "condition",
      "name": "测试结果评估",
      "position": {
        "x": 1268.7487497852471,
        "y": 98.51974780890134
      },
      "config": {
        "conditions": [
          {
            "label": "测试通过",
            "expression": "{{coverageScore}} >= 80",
            "targetNode": "generate-report"
          }
        ],
        "defaultNode": "fix-issues"
      },
      "updatedAt": "2026-04-09T00:35:23.258Z"
    },
    {
      "id": "generate-report",
      "type": "agent",
      "name": "生成测试报告",
      "position": {
        "x": 1471.7092541674444,
        "y": 2.6319298848429185
      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "tester-agent"
            }
          ],
          "failureStrategy": {
            "action": "abort"
          }
        },
        "taskTemplate": "生成测试报告：汇总所有测试结果，生成HTML格式的测试报告，保存到 {{context.outputPath}}",
        "inputs": [
          {
            "name": "coverageReport",
            "source": "prev-output",
            "sourceKey": "coverage-analysis:coverageReport"
          }
        ],
        "outputs": [
          {
            "name": "finalReport",
            "extractPath": "$"
          }
        ],
        "timeout": 600000
      },
      "updatedAt": "2026-04-09T00:35:22.594Z",
      "description": ""
    },
    {
      "id": "fix-issues",
      "type": "agent",
      "name": "修复问题",
      "position": {
        "x": 1439.143705963274,
