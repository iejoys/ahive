      },
      "config": {
        "executor": {
          "mode": "single",
          "executors": [
            {
              "type": "agent",
              "id": "coder-agent"
            }
          ],
          "failureStrategy": {
            "action": "retry",
            "retryCount": 2
          }
        },
        "taskTemplate": "根据测试结果修复代码问题：分析失败的测试用例，修复代码缺陷",
        "inputs": [
          {
            "name": "coverageReport",
            "source": "prev-output",
            "sourceKey": "coverage-analysis:coverageReport"
          }
        ],
        "timeout": 1800000
      },
      "updatedAt": "2026-04-08T02:48:38.468Z"
