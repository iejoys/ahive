        { "tool": "zhinest_render_incremental", "input": {}, "purpose": "增量渲染" }
      ]
    },
    {
      "scenario": "管理站点配置",
      "description": "Agent 读取和修改站点配置",
      "steps": [
        { "tool": "zhinest_config_get", "input": {}, "purpose": "获取当前配置" },
        { "tool": "zhinest_config_update", "input": { "key": "site_name", "value": "智巢" }, "purpose": "更新站点名称" }
      ]
    }
  ],

