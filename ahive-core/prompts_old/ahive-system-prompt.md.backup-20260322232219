## 8. 完整示例：游戏开发工作流

以下示例展示了一个完整的游戏开发工作流，包含所有常用节点类型的搭配：

```json
{
  "id": "workflow-game-dev",
  "name": "游戏开发工作流",
  "description": "完整的游戏开发流程：设计 → 开发 → 测试 → 发布",
  
  "context": {
    "projectPath": "{{PROJECT_ROOT}}/games/my-game",
    "outputPath": "{{PROJECT_ROOT}}/games/my-game/dist",
    "assets": {
      "images": "{{PROJECT_ROOT}}/games/my-game/assets/images",
      "audio": "{{PROJECT_ROOT}}/games/my-game/assets/audio",
      "code": "{{PROJECT_ROOT}}/games/my-game/src",
      "docs": "{{PROJECT_ROOT}}/games/my-game/docs"
    }
  },
  
  "nodes": [
    // ========== 初始化 ==========
    {
      "id": "init",
      "type": "variable",
      "name": "初始化项目配置",
      "config": {
        "name": "projectConfig",
        "value": {
          "gameName": "MyGame",
          "version": "1.0.0",
          "platform": "web"
        },
        "type": "json"
      }
    },
    
    // ========== 阶段一：设计 ==========
    {
      "id": "phase-design",
      "type": "milestone",
      "name": "阶段一：需求与设计",
      "config": {
        "description": "完成需求分析和游戏设计",
        "waitForCompletion": true
      }
    },
    {
      "id": "requirement-analysis",
      "type": "agent",
      "name": "需求分析",
      "config": {
        "executor": {
          "mode": "single",
          "executors": [{ "type": "agent", "id": "analyst-agent" }]
        },
        "taskTemplate": "分析游戏需求，确定核心玩法、目标用户、平台适配。输出需求文档到 {{context.assets.docs}}/requirements.md",
        "outputs": [
          { "name": "requirementsDoc", "extractPath": "$" }
        ],
        "timeout": 3600000
      }
    },
    {
      "id": "game-design",
      "type": "agent",
      "name": "游戏设计",
      "config": {
        "executor": {
          "mode": "single",
          "executors": [{ "type": "agent", "id": "designer-agent" }]
        },
        "taskTemplate": "基于需求分析，设计游戏机制、关卡、角色、UI。输出游戏设计文档(GDD)到 {{context.assets.docs}}/GDD.md",
        "inputs": [
          { "name": "requirementsDoc", "source": "prev-output", "sourceKey": "requirement-analysis:requirementsDoc" }
        ],
        "outputs": [
