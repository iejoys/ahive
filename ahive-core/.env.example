# AHIVE Core - 环境配置示例
# 复制此文件为 .env 并填写实际值

# ============ 大模型配置 ============

# 阿里云百炼 (Qwen) - 主用
ALIYUN_API_KEY=your-aliyun-api-key-here
ALIYUN_MODEL=qwen3-max-2026-01-23

# MiniMax (备选)
# MINIMAX_API_KEY=your-minimax-api-key-here
# MINIMAX_MODEL=abab6.5

# DeepSeek (备选)
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_MODEL=deepseek-chat

# ============ 服务配置 ============

AHIVE_PORT=18790
AHIVE_HOST=127.0.0.1

# ============ 日志配置 ============

AHIVE_LOG_LEVEL=info

# ============ 其他配置 ============

AHIVE_ENV=development
AHIVE_MAX_CONCURRENCY=5
AHIVE_TIMEOUT_MS=30000